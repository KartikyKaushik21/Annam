<%- layout('layouts/boilerplate') %>

    <body>

        <section class="hero" id="home">

            <div class="container">

                <div class="row align-items-center">

                    <div class="col-lg-6" data-aos="fade-right">

                        <h1>

                            Reduce Food Waste

                            <span>

                                Feed Lives

                            </span>

                        </h1>

                        <p>

                            Connecting Donors,
                            NGOs,
                            Volunteers and Beneficiaries
                            through an AI Powered Food Donation Platform.

                        </p>

                        <div class="mt-4">

                            <a href="#donate" class="btn btn-success btn-lg">

                                Donate Food

                            </a>

                            <a href="#about" class="btn btn-outline-light btn-lg ms-2">

                                Learn More

                            </a>

                        </div>

                    </div>

                    <div class="col-lg-6 text-center" data-aos="fade-left">

                        <img src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=900"
                            class="img-fluid hero-img">

                    </div>

                </div>

            </div>

        </section>

        <section class="stats">

            <div class="container">

                <div class="row text-center">

                    <div class="col-md-3">

                        <div class="stat-box">

                            <i class="fa-solid fa-utensils"></i>

                            <h2 class="counter" data-target="15000">0</h2>

                            <p>Meals Served</p>

                        </div>

                    </div>

                    <div class="col-md-3">

                        <div class="stat-box">

                            <i class="fa-solid fa-users"></i>

                            <h2 class="counter" data-target="800">0</h2>

                            <p>Registered Donors</p>

                        </div>

                    </div>

                    <div class="col-md-3">

                        <div class="stat-box">

                            <i class="fa-solid fa-handshake"></i>

                            <h2 class="counter" data-target="350">0</h2>

                            <p>NGO Partners</p>

                        </div>

                    </div>

                    <div class="col-md-3">

                        <div class="stat-box">

                            <i class="fa-solid fa-earth-asia"></i>

                            <h2 class="counter" data-target="1200">0</h2>

                            <p>Volunteers</p>

                        </div>

                    </div>

                </div>

            </div>

        </section>

        <section class="about py-5" id="about">

            <div class="container">

                <div class="text-center mb-5">

                    <h2>

                        About Our Platform

                    </h2>

                    <p>

                        Our AI-powered platform bridges the gap between food donors, NGOs,
                        volunteers, and beneficiaries by ensuring surplus food reaches those who need it most.

                    </p>

                </div>

                <div class="row">

                    <div class="col-md-4" data-aos="zoom-in">

                        <div class="about-card">

                            <i class="fa-solid fa-hand-holding-heart"></i>

                            <h4>

                                Donate

                            </h4>

                            <p>

                                Restaurants, hotels, households,
                                and event organizers can donate surplus food.

                            </p>

                        </div>

                    </div>

                    <div class="col-md-4" data-aos="zoom-in" data-aos-delay="200">

                        <div class="about-card">

                            <i class="fa-solid fa-truck-fast"></i>

                            <h4>

                                Pickup

                            </h4>

                            <p>

                                Nearby volunteers receive pickup requests instantly.

                            </p>

                        </div>

                    </div>

                    <div class="col-md-4" data-aos="zoom-in" data-aos-delay="400">

                        <div class="about-card">

                            <i class="fa-solid fa-bowl-food"></i>

                            <h4>

                                Distribution

                            </h4>

                            <p>

                                NGOs distribute food quickly using AI demand prediction.

                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </section>

        <!--==========================
HOW IT WORKS
===========================-->

        <section class="process py-5">

            <div class="container">

                <div class="text-center mb-5">

                    <h2>

                        How It Works

                    </h2>

                </div>

                <div class="row text-center">

                    <div class="col-md-3">

                        <div class="step" data-aos="zoom-in">

                            <div class="circle">

                                1

                            </div>

                            <h5>

                                Register

                            </h5>

                            <p>

                                Create donor or volunteer account.

                            </p>

                        </div>

                    </div>

                    <div class="col-md-3">

                        <div class="step" data-aos="zoom-in">

                            <div class="circle">

                                2

                            </div>

                            <h5>

                                Upload Food

                            </h5>

                            <p>

                                Add quantity,
                                image,
                                pickup location.

                            </p>

                        </div>

                    </div>

                    <div class="col-md-3">

                        <div class="step" data-aos="zoom-in">

                            <div class="circle">

                                3

                            </div>

                            <h5>

                                AI Verification

                            </h5>

                            <p>

                                AI checks freshness and predicts demand.

                            </p>

                        </div>

                    </div>

                    <div class="col-md-3">

                        <div class="step" data-aos="zoom-in">

                            <div class="circle">

                                4

                            </div>

                            <h5>

                                Delivery

                            </h5>

                            <p>

                                Volunteer delivers food to NGOs.

                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </section>
        <!-- ==========================
FEATURES
=========================== -->

        <section id="features" class="py-5 bg-light">

            <div class="container">

                <div class="text-center mb-5" data-aos="fade-up">

                    <h2 class="fw-bold">Platform Features</h2>

                    <p class="text-muted">
                        Making food donation smarter, faster and more transparent.
                    </p>

                </div>

                <div class="row g-4">

                    <div class="col-lg-3 col-md-6" data-aos="zoom-in">

                        <div class="feature-card text-center">

                            <div class="feature-icon bg-success">
                                <i class="fas fa-hand-holding-heart"></i>
                            </div>

                            <h4>Easy Donation</h4>

                            <p>
                                Donate surplus food in less than one minute.
                            </p>

                        </div>

                    </div>

                    <div class="col-lg-3 col-md-6" data-aos="zoom-in" data-aos-delay="100">

                        <div class="feature-card text-center">

                            <div class="feature-icon bg-primary">
                                <i class="fas fa-truck"></i>
                            </div>

                            <h4>Fast Pickup</h4>

                            <p>
                                Nearby volunteers are notified instantly.
                            </p>

                        </div>

                    </div>

                    <div class="col-lg-3 col-md-6" data-aos="zoom-in" data-aos-delay="200">

                        <div class="feature-card text-center">

                            <div class="feature-icon bg-warning">
                                <i class="fas fa-chart-line"></i>
                            </div>

                            <h4>Analytics</h4>

                            <p>
                                Track donations, inventory and food distribution.
                            </p>

                        </div>

                    </div>

                    <div class="col-lg-3 col-md-6" data-aos="zoom-in" data-aos-delay="300">

                        <div class="feature-card text-center">

                            <div class="feature-icon bg-danger">
                                <i class="fas fa-robot"></i>
                            </div>

                            <h4>AI Powered</h4>

                            <p>
                                Smart freshness detection and demand prediction.
                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </section>


        <!-- ==========================
AI FOOD FRESHNESS
=========================== -->

        <section id="ai" class="py-5">

            <div class="container">

                <div class="text-center mb-5" data-aos="fade-up">

                    <h2 class="fw-bold">

                        🤖 AI Food Freshness Prediction

                    </h2>

                    <p class="text-muted">

                        Upload a food image and let Artificial Intelligence
                        predict its freshness before donation.

                    </p>

                </div>

                <div class="row align-items-center">

                    <div class="col-lg-6" data-aos="fade-right">

                        <div class="card shadow-lg border-0 p-4">

                            <h4 class="mb-4">

                                Upload Food Image

                            </h4>

                            <input type="file" class="form-control mb-3">

                            <button class="btn btn-success btn-lg">

                                <i class="fas fa-magnifying-glass"></i>

                                Analyze Food

                            </button>

                            <hr>

                            <h5 class="mt-3">

                                Supported Food

                            </h5>

                            <div class="mt-3">

                                <span class="badge bg-success m-1">
                                    Rice
                                </span>

                                <span class="badge bg-success m-1">
                                    Bread
                                </span>

                                <span class="badge bg-success m-1">
                                    Vegetables
                                </span>

                                <span class="badge bg-success m-1">
                                    Fruits
                                </span>

                                <span class="badge bg-success m-1">
                                    Packed Meals
                                </span>

                                <span class="badge bg-success m-1">
                                    Snacks
                                </span>

                            </div>

                        </div>

                    </div>


                    <div class="col-lg-6" data-aos="fade-left">

                        <div class="card shadow-lg border-0 p-4">

                            <h4 class="text-center mb-4">

                                AI Analysis Result

                            </h4>

                            <table class="table">

                                <tr>

                                    <th>Food</th>

                                    <td>Vegetable Biryani</td>

                                </tr>

                                <tr>

                                    <th>Freshness</th>

                                    <td>

                                        <div class="progress">

                                            <div class="progress-bar bg-success" style="width:92%">

                                                92%

                                            </div>

                                        </div>

                                    </td>

                                </tr>

                                <tr>

                                    <th>Estimated Meals</th>

                                    <td>48 People</td>

                                </tr>

                                <tr>

                                    <th>Shelf Life</th>

                                    <td>5 Hours Remaining</td>

                                </tr>

                                <tr>

                                    <th>Status</th>

                                    <td>

                                        <span class="badge bg-success">

                                            Safe For Donation

                                        </span>

                                    </td>

                                </tr>

                            </table>

                        </div>

                    </div>

                </div>

            </div>

        </section>


        <!-- ==========================
QR CODE VERIFICATION
=========================== -->

        <section id="qr" class="py-5 bg-light">

            <div class="container">

                <div class="text-center mb-5" data-aos="fade-up">

                    <h2 class="fw-bold">

                        📱 QR Code Verification

                    </h2>

                    <p class="text-muted">

                        Every donation receives a unique QR Code
                        to verify pickup and delivery.

                    </p>

                </div>

                <div class="row align-items-center">

                    <div class="col-lg-6" data-aos="fade-right">

                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=350x350&data=FoodDonationPlatform"
                            class="img-fluid rounded shadow">

                    </div>

                    <div class="col-lg-6" data-aos="fade-left">

                        <div class="timeline">

                            <div class="timeline-item">

                                <i class="fas fa-qrcode text-success"></i>

                                <h5>

                                    QR Generated

                                </h5>

                                <p>

                                    A QR code is automatically created
                                    when food is donated.

                                </p>

                            </div>

                            <div class="timeline-item">

                                <i class="fas fa-mobile-screen-button text-primary"></i>

                                <h5>

                                    Volunteer Scan

                                </h5>

                                <p>

                                    Volunteer scans QR during pickup.

                                </p>

                            </div>

                            <div class="timeline-item">

                                <i class="fas fa-check-circle text-warning"></i>

                                <h5>

                                    Verification

                                </h5>

                                <p>

                                    Donation gets verified instantly.

                                </p>

                            </div>

                            <div class="timeline-item">

                                <i class="fas fa-box-open text-danger"></i>

                                <h5>

                                    Delivery Completed

                                </h5>

                                <p>

                                    NGO scans again to confirm delivery.

                                </p>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </section>
        <!-- ==========================
AI DEMAND PREDICTION
=========================== -->

        <section id="prediction" class="py-5">

            <div class="container">

                <div class="text-center mb-5" data-aos="fade-up">

                    <h2 class="fw-bold">🧠 AI Demand Prediction</h2>

                    <p class="text-muted">
                        AI analyzes previous donations and predicts which food items are expected to be in high demand.
                    </p>

                </div>

                <div class="row g-4">

                    <div class="col-lg-4" data-aos="zoom-in">

                        <div class="card prediction-card shadow border-0 h-100">

                            <div class="card-body text-center">

                                <i class="fas fa-bowl-rice fa-3x text-success mb-3"></i>

                                <h4>Rice</h4>

                                <span class="badge bg-danger fs-6">High Demand</span>

                                <div class="progress mt-4">

                                    <div class="progress-bar bg-danger" style="width:95%">
                                        95%
                                    </div>

                                </div>

                                <p class="mt-3 text-muted">
                                    Expected shortage in the next 24 hours.
                                </p>

                            </div>

                        </div>

                    </div>

                    <div class="col-lg-4" data-aos="zoom-in" data-aos-delay="150">

                        <div class="card shadow border-0 h-100">

                            <div class="card-body text-center">

                                <i class="fas fa-bread-slice fa-3x text-warning mb-3"></i>

                                <h4>Bread</h4>

                                <span class="badge bg-warning text-dark fs-6">
                                    Medium Demand
                                </span>

                                <div class="progress mt-4">

                                    <div class="progress-bar bg-warning text-dark" style="width:70%">
                                        70%
                                    </div>

                                </div>

                                <p class="mt-3 text-muted">
                                    Moderate stock available.
                                </p>

                            </div>

                        </div>

                    </div>

                    <div class="col-lg-4" data-aos="zoom-in" data-aos-delay="300">

                        <div class="card shadow border-0 h-100">

                            <div class="card-body text-center">

                                <i class="fas fa-apple-whole fa-3x text-primary mb-3"></i>

                                <h4>Fruits</h4>

                                <span class="badge bg-success fs-6">
                                    Low Demand
                                </span>

                                <div class="progress mt-4">

                                    <div class="progress-bar bg-success" style="width:45%">
                                        45%
                                    </div>

                                </div>

                                <p class="mt-3 text-muted">
                                    Current inventory is sufficient.
                                </p>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </section>


        <!-- ==========================
VOLUNTEER LEADERBOARD
=========================== -->

        <section id="leaderboard" class="py-5 bg-light">

            <div class="container">

                <div class="text-center mb-5" data-aos="fade-up">

                    <h2 class="fw-bold">

                        🏆 Volunteer Leaderboard

                    </h2>

                    <p class="text-muted">

                        Recognizing our most dedicated volunteers.

                    </p>

                </div>

                <div class="table-responsive shadow rounded">

                    <table class="table table-hover table-striped align-middle mb-0">

                        <thead class="table-success">

                            <tr>

                                <th>Rank</th>

                                <th>Volunteer</th>

                                <th>Completed Deliveries</th>

                                <th>Points</th>

                                <th>Badge</th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr>

                                <td>🥇</td>

                                <td>Rahul Sharma</td>

                                <td>182</td>

                                <td>5400</td>

                                <td>

                                    <span class="badge bg-warning text-dark">

                                        Gold

                                    </span>

                                </td>

                            </tr>

                            <tr>

                                <td>🥈</td>

                                <td>Priya Singh</td>

                                <td>171</td>

                                <td>5120</td>

                                <td>

                                    <span class="badge bg-secondary">

                                        Silver

                                    </span>

                                </td>

                            </tr>

                            <tr>

                                <td>🥉</td>

                                <td>Aman Verma</td>

                                <td>160</td>

                                <td>4860</td>

                                <td>

                                    <span class="badge bg-danger">

                                        Bronze

                                    </span>

                                </td>

                            </tr>

                            <tr>

                                <td>4</td>

                                <td>Neha Kapoor</td>

                                <td>145</td>

                                <td>4510</td>

                                <td>

                                    <span class="badge bg-primary">

                                        Star

                                    </span>

                                </td>

                            </tr>

                            <tr>

                                <td>5</td>

                                <td>Rohit Kumar</td>

                                <td>139</td>

                                <td>4330</td>

                                <td>

                                    <span class="badge bg-success">

                                        Rising

                                    </span>

                                </td>

                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

        </section>


        <!-- ==========================
OUR IMPACT
=========================== -->

        <section class="py-5">

            <div class="container">

                <div class="text-center mb-5">

                    <h2 class="fw-bold">

                        🌍 Our Impact

                    </h2>

                </div>

                <div class="row text-center g-4">

                    <div class="col-md-3">

                        <div class="impact-box">

                            <h3>15K+</h3>

                            <p>Meals Served</p>

                        </div>

                    </div>

                    <div class="col-md-3">

                        <div class="impact-box">

                            <h3>5 Tons</h3>

                            <p>Food Saved</p>

                        </div>

                    </div>

                    <div class="col-md-3">

                        <div class="impact-box">

                            <h3>1200+</h3>

                            <p>Volunteers</p>

                        </div>

                    </div>

                    <div class="col-md-3">

                        <div class="impact-box">

                            <h3>350+</h3>

                            <p>NGO Partners</p>

                        </div>

                    </div>

                </div>

            </div>

        </section>


        <!-- ==========================
CONTACT
=========================== -->

        <section id="contact" class="py-5 bg-light">

            <div class="container">

                <div class="text-center mb-5">

                    <h2 class="fw-bold">

                        Contact Us

                    </h2>

                    <p>

                        We'd love to hear from you.

                    </p>

                </div>

                <div class="row">

                    <div class="col-lg-6">

                        <input class="form-control mb-3" placeholder="Your Name">

                        <input class="form-control mb-3" placeholder="Email">

                        <input class="form-control mb-3" placeholder="Phone Number">

                        <textarea class="form-control mb-3" rows="5" placeholder="Message"></textarea>

                        <button class="btn btn-success btn-lg w-100">

                            Send Message

                        </button>

                    </div>

                    <div class="col-lg-6">

                        <div class="card shadow border-0 p-4 h-100">

                            <h4>

                                Office Information

                            </h4>

                            <hr>

                            <p>

                                <i class="fas fa-location-dot text-success"></i>

                                Lovely Professional University,
                                Punjab

                            </p>

                            <p>

                                <i class="fas fa-phone text-success"></i>

                                +91 9876543210

                            </p>

                            <p>

                                <i class="fas fa-envelope text-success"></i>

                                fooddonation@email.com

                            </p>

                            <p>

                                <i class="fas fa-clock text-success"></i>

                                Mon - Sat | 9 AM - 6 PM

                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </section>

        <!-- Back To Top -->

        <button id="topBtn" class="btn btn-success">

            <i class="fas fa-arrow-up"></i>

        </button>
    </body>

    </html>